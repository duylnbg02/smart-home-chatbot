# Environment variables
MONGODB_URI=mongodb://localhost:27017
# Hoặc dùng MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatbot?retryWrites=true&w=majority
DEBUG=True
FLASK_ENV=development
GOOGLE_API_KEY=...

# WeatherAPI
WEATHER_API_KEY=...
WEATHER_CITY=Hanoi
WEATHER_UPDATE_INTERVAL=3600  # Cập nhật mỗi 1 giờ

# MQTT credentials
MQTT_BROKER=...mqtt.example.com
MQTT_PORT=8883
MQTT_USERNAME=mqtt-backend
MQTT_PASSWORD=Test1234

